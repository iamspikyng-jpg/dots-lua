{
  "positionX": "right", "positionY": "top",
  "control-center-positionX": "right", "control-center-positionY": "top",
  "layer": "overlay", "layer-shell": true,
  "control-center-margin-top": 40, "control-center-margin-bottom": 40,
  "control-center-margin-right": 20, "control-center-margin-left": 20,
  "notification-2fa-action": true, "notification-inline-replies": true,
  "notification-icon-size": 48, "notification-body-image-height": 160,
  "notification-body-image-width": 240, "timeout": 6, "timeout-low": 3,
  "timeout-critical": 0, "fit-to-screen": true,
  "control-center-width": 420, "control-center-height": 680,
  "notification-window-width": 400, "keyboard-shortcuts": true,
  "image-visibility": "when-available", "hide-on-clear": true,
  "hide-on-action": true, "script-fail-notify": true,
  "widgets": ["inhibitors", "title", "dnd", "notifications", "mpris", "volume", "backlight", "buttons-grid"],
  "widget-config": {
    "inhibitors": { "text": "Inhibitors", "button-text": "Clear All", "clear-all-button": true },
    "title": { "text": "Notifications", "clear-all-button": true, "button-text": "Clear All" },
    "dnd": { "text": "Do Not Disturb" },
    "label": { "max-lines": 5, "text": "Notification Center" },
    "mpris": { "image-size": 40, "image-radius": 6 },
    "volume": { "label": "\uf028" },
    "backlight": { "label": "\uf185" },
    "buttons-grid": {
      "actions": [
        { "label": "\uf108", "command": "rofi -show drun -theme ~/.local/share/rofi/themes/grid.rasi" },
        { "label": "\uf041", "command": "kitty" },
        { "label": "\uf9c9", "command": "zen-browser" },
        { "label": "\uf07c", "command": "thunar" },
        { "label": "\uf026", "command": "pavucontrol" },
        { "label": "\uf011", "command": "~/.config/hypr/scripts/wlogout.sh" }
      ]
    }
  }
}
